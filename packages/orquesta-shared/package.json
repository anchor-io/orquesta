{
  "name": "@anchorsoft/orquesta-shared",
  "private": true,
  "version": "0.0.1",
  "description": "Anchor Agent Orchestrator Shared Package",
  "author": "Anchor",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "sideEffects": false,
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "tsgo --noEmit",
    "lint": "oxlint .",
    "test": "TMPDIR=/tmp vitest run --passWithNoTests",
    "test:unit": "TMPDIR=/tmp vitest run --passWithNoTests",
    "test:watch": "TMPDIR=/tmp vitest",
    "quality": "pnpm run format:check && pnpm run check && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "vitest": "^4.1.8"
  }
}
