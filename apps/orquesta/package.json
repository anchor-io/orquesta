{
  "name": "@anchorsoft/orquesta",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:unit": "TMPDIR=/tmp vitest run --passWithNoTests",
    "test:unit:watch": "TMPDIR=/tmp vitest",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:e2e": "playwright test",
    "quality": "pnpm run format:check && pnpm run check && pnpm run lint && pnpm run test",
    "docker:up": "docker compose -f compose.yml up -d",
    "docker:down": "docker compose -f compose.yml down",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.18.2",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "next",
    "@sveltejs/kit": "next",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24",
    "@valibot/to-json-schema": "^1.7.1",
    "@vitest/browser-playwright": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "^12.10.0",
    "jsonc-parser": "^3.3.1",
    "valibot": "^1.4.1"
  }
}
