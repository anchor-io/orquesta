{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["build/**", ".svelte-kit/**", "!.svelte-kit/cache/**"],
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "test": {
      "dependsOn": ["transit"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [],
      "env": ["DATABASE_URL", "CI"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": [],
      "env": ["DATABASE_URL", "CI"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "HOST", "PORT", "ORIGIN", "NODE_ENV"]
    },
    "preview": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "HOST", "PORT", "ORIGIN", "NODE_ENV"]
    }
  }
}
