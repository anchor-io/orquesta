{
  "name": "@anchorsoft/orquesta-electron",
  "private": true,
  "version": "0.0.1",
  "description": "Anchor Agent Orchestrator",
  "author": "Anchor",
  "desktopName": "anchor-orquesta.desktop",
  "type": "module",
  "main": "out/main.js",
  "scripts": {
    "copy:server": "tsx scripts/copy-server.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "tsgo --noEmit",
    "lint": "oxlint .",
    "quality": "pnpm run format:check && pnpm run check && pnpm run lint",
    "build": "vite build",
    "package": "electron-builder",
    "serve": "electron out/main.js serve",
    "desktop": "electron out/main.js"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.22.4",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "net.anchorsoft.orquesta",
    "productName": "Anchor Orchestrator",
    "executableName": "anchor-orquesta",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/**/*",
      "build/node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "out/**/*",
      "build/**/*"
    ],
    "linux": {
      "icon": "resources/icon.svg",
      "syncDesktopName": true,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "artifactName": "anchor-orquesta-${version}-${arch}.${ext}"
    }
  }
}
