{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": ["CI", "GITHUB_ACTIONS"],
    "tasks": {
        "transit": {
            "dependsOn": ["^transit"]
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "check": {
            "dependsOn": ["transit"],
            "outputs": []
        },
        "format": {
            "cache": false
        },
        "format:check": {
            "outputs": []
        },
        "lint": {
            "dependsOn": ["transit"],
            "outputs": []
        },
        "test": {
            "dependsOn": ["transit"],
            "outputs": []
        },
        "test:unit": {
            "dependsOn": ["transit"],
            "outputs": []
        },
        "test:e2e": {
            "dependsOn": ["build"],
            "cache": false,
            "outputs": []
        },
        "copy:server": {
            "outputs": []
        },
        "package": {
            "dependsOn": ["build"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "preview": {
            "cache": false,
            "persistent": true
        }
    }
}
